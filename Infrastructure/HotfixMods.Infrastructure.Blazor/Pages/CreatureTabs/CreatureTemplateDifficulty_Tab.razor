                </RightContent>
            </InlineGroup>
        </MudItem>
        <MudItem xs="3">
            <Input_Element T="uint" @bind-Value="Value.GoldMin" ValueCompare="ValueCompare?.GoldMin" Label="@nameof(Value.GoldMin).ToDisplayName()" OnInfoAdornmentClick="@(OpenInfoDialog(nameof(CreatureTemplateDifficulty.GoldMin)))" />
            <Input_Element T="uint" @bind-Value="Value.GoldMax" ValueCompare="ValueCompare?.GoldMax" Label="@nameof(Value.GoldMax).ToDisplayName()" OnInfoAdornmentClick="@(OpenInfoDialog(nameof(CreatureTemplateDifficulty.GoldMax)))" />
