        </MudItem>
    </PagedDtoContentPage>
    <PagedDtoContentPage>
        <MudItem xs="3">
            <Input_Element T="uint" @bind-Value="Value.StaticFlags1" ValueCompare="ValueCompare?.StaticFlags1" Label="Static Flags 1" OnInfoAdornmentClick="@(OpenInfoDialog(nameof(CreatureTemplateDifficulty.StaticFlags1)))" />
