            <Placeholder_Element Amount="4" />
        </MudItem>
        <MudItem xs="3">
            <Input_Element T="uint" @bind-Value="Value.StaticFlags5" ValueCompare="ValueCompare?.StaticFlags5" Label="Static Flags 5" OnInfoAdornmentClick="@(OpenInfoDialog(nameof(CreatureTemplateDifficulty.StaticFlags5)))" />
